# =============================================================================
# Sample environment for local development
# -----------------------------------------------------------------------------
# Copy to `.env` and adjust:
#   cp .env.example .env
#
# Start dependencies (Postgres, PgBouncer, Redis):
#   docker compose -f docker/docker-compose.yml up -d
#
# The app loads this file automatically via dotenv when you run npm run dev / npm start
# from the project root (cwd must be the repo root).
# =============================================================================

# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
METRICS_PORT=9090
SHUTDOWN_GRACE_MS=30000
LOG_LEVEL=debug

# PostgreSQL — matches docker-compose `postgres` service (direct: 5432, via PgBouncer: 6432)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=app
DB_USER=app
DB_PASSWORD=app
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10
# Idle client reaped by pool (ms); avoids holding PgBouncer/server slots forever
DB_POOL_IDLE_TIMEOUT_MS=30000
# PostgreSQL statement_timeout per connection (ms)
DB_STATEMENT_TIMEOUT_MS=60000
DB_CONNECT_MAX_RETRIES=5
DB_CONNECT_RETRY_BASE_MS=500

# Redis
# local = in-memory stub (no TCP). Use redis-primary + REDIS_HOST for real Redis (compose: 6379).
REDIS_MODE=redis-primary
REDIS_TOPOLOGY=standalone
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Cluster (when REDIS_TOPOLOGY=cluster and REDIS_MODE is not local):
# REDIS_CLUSTER_NODES=[{"host":"127.0.0.1","port":6379}]
REDIS_SYNC_INTERVAL_MS=10000

# Rate limiting
RATE_LIMIT_DISABLED=false
RATE_LIMIT_BYPASS_CIDRS=
RL_IP_MAX_TOKENS=100
RL_IP_REFILL_RATE=10
RL_MAX_IPS=500000
RL_NEW_IP_RATE_MAX=1000
LATENCY_CB_DELTA_MS=5
LATENCY_CB_WINDOW_SIZE=10000
LATENCY_CB_CHECK_INTERVAL_MS=100
LATENCY_CB_RECOVERY_MS=5000
LATENCY_CB_WARMUP_MS=30000

# Security — include origins your browser will send (e.g. dev server or Swagger)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BODY_SIZE_LIMIT=100kb
TRUSTED_PROXY_DEPTH=2
